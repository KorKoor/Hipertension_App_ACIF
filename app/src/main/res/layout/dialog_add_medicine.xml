<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Detalles del Medicamento"
        android:textColor="#466B95"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Qué medicamento es?"
        android:textSize="12sp"
        android:textColor="#64748B"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etNombreMed"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:hint="Ej: Losartán"
        android:background="@drawable/bg_field"
        android:paddingHorizontal="16dp"
        android:drawableStart="@drawable/ic_search"
        android:drawablePadding="12dp"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dosis"
                android:textSize="12sp"
                android:textColor="#64748B"/>
            <EditText
                android:id="@+id/etDosisMed"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="5"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_field"
                android:paddingHorizontal="16dp"
                android:gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unidad"
                android:textSize="12sp"
                android:textColor="#64748B"/>
            <Spinner
                android:id="@+id/spinnerUnidad"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_field"
                android:entries="@array/unidades_medicina" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F1F5F9"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Programación"
        android:textColor="#466B95"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etFechaMed"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:hint="Fecha de inicio"
        android:focusable="false"
        android:clickable="true"
        android:background="@drawable/bg_field"
        android:paddingHorizontal="16dp"
        android:drawableStart="@drawable/ic_calendar"
        android:drawablePadding="12dp"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etHoraMed"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:hint="Hora de la primera toma"
        android:focusable="false"
        android:clickable="true"
        android:background="@drawable/bg_field"
        android:paddingHorizontal="16dp"
        android:drawableStart="@drawable/ic_access_time"
        android:drawablePadding="12dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Cada cuánto tiempo?"
        android:textSize="12sp"
        android:textColor="#64748B"
        android:layout_marginBottom="4dp"/>
    <Spinner
        android:id="@+id/spinnerFrecuencia"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="@drawable/bg_field"
        android:entries="@array/frecuencias_medicina"/>

</LinearLayout>