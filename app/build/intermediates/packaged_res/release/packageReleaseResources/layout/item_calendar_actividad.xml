<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#466B95"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_access_time"
                    app:tint="#466B95"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvActividadHora"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#466B95"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    tools:text="10:00 AM" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvActividadLista"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                tools:text="Caminar (45 min), Estiramientos (15 min)" />

            <TextView
                android:id="@+id/tvActividadNota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#F1F5F9"
                android:padding="8dp"
                android:textSize="13sp"
                android:fontStyle="italic"
                android:textColor="#64748B"
                android:visibility="gone"
                tools:text="Nota: Caminata ligera por el parque."
                tools:visibility="visible"/>

        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/actividadfisica"
            app:tint="#CBD5E1" />

    </LinearLayout>
</androidx.cardview.widget.CardView>