<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:context=".MainActivity">

    <!-- Contenido scrollable -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:fitsSystemWindows="true"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Header -->
            <androidx.cardview.widget.CardView
                android:id="@+id/headerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <!-- Foto perfil más grande a la izquierda -->
                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/profileImage"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        app:civ_border_width="2dp"
                        app:civ_border_color="#F1F5F9"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:src="@drawable/profile" />

                    <!-- Icono racha arriba a la derecha -->
                    <ImageView
                        android:id="@+id/streakIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:srcCompat="@drawable/streak"
                        android:layout_marginEnd="6dp"
                        app:layout_constraintEnd_toStartOf="@id/streakText"
                        app:layout_constraintTop_toTopOf="parent"
                        android:contentDescription="@string/streak_icon_desc" />

                    <!-- Texto racha arriba a la derecha -->
                    <TextView
                        android:id="@+id/streakText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 días"
                        android:textColor="#466B95"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/streakIcon" />

                    <!-- Saludo debajo de la racha, alineado a la derecha -->
                    <TextView
                        android:id="@+id/headerGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#64748B"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        tools:text="¡Hola!"
                        app:layout_constraintTop_toBottomOf="@id/streakText"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Nombre/usuario debajo del saludo -->
                    <TextView
                        android:id="@+id/headerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#1E293B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="Usuario"
                        app:layout_constraintTop_toBottomOf="@id/headerGreeting"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card presión arterial -->
            <androidx.cardview.widget.CardView
                android:id="@+id/pressureCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="8dp"
                app:layout_constraintTop_toBottomOf="@id/headerCard">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tvUltimaMedicionTitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Última medición"
                        android:textColor="#466B95"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <LinearLayout
                        android:id="@+id/dateTimeLayout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:orientation="vertical"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <TextView
                            android:id="@+id/dateText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="16 Ene, 2026"
                            android:textColor="#94A3B8"
                            android:textStyle="bold"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/timeText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="08:35 PM"
                            android:textColor="#94A3B8"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Valores presión -->
                    <LinearLayout
                        android:id="@+id/pressureValuesRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        app:layout_constraintTop_toBottomOf="@id/tvUltimaMedicionTitulo">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/labelSistolica"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SISTÓLICA"
                                android:textColor="#64748B"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/valueSistolica"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="120"
                                android:textColor="#466B95"
                                android:textSize="44sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="mmHg"
                                android:textSize="10sp"
                                android:textColor="#94A3B8"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="60dp"
                            android:background="#F1F5F9"
                            android:layout_gravity="center"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/labelDiastolica"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DIASTÓLICA"
                                android:textColor="#64748B"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/valueDiastolica"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="80"
                                android:textColor="#466B95"
                                android:textSize="44sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="mmHg"
                                android:textSize="10sp"
                                android:textColor="#94A3B8"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/pulsoContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="24dp"
                        android:background="#F8FAFC"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/pressureValuesRow">

                        <TextView
                            android:id="@+id/labelPulso"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PULSO: "
                            android:textColor="#94A3B8"
                            android:textSize="11sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/valuePulso"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="72 LPM"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:id="@+id/divider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F1F5F9"
                        android:layout_marginTop="20dp"
                        app:layout_constraintTop_toBottomOf="@id/pulsoContainer"/>

                    <TextView
                        android:id="@+id/displayNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sin nota adicional"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:fontStyle="italic"
                        android:layout_marginTop="16dp"
                        android:background="#F8FAFC"
                        android:padding="12dp"
                        app:layout_constraintTop_toBottomOf="@id/divider"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddValues"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Registrar Presión"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="20dp"
                        app:layout_constraintTop_toBottomOf="@id/displayNote"
                        android:layout_marginTop="24dp"
                        android:backgroundTint="#466B95"
                        app:elevation="4dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerHistorial"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ver mi historial completo"
                        android:textAllCaps="false"
                        android:textColor="#466B95"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/btnAddValues"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Próxima dosis -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNextDose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#E2E8F0"
                app:layout_constraintTop_toBottomOf="@id/pressureCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRÓXIMA MEDICACIÓN"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="#466B95"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tvProximaDosis"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1E293B"
                        tools:text="Hoy, 10:00 AM"/>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:background="#466B95"
                        android:layout_marginTop="12dp"
                        android:alpha="0.3"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:background="#F8FAFC"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_meds"
                            app:tint="#466B95" />

                        <TextView
                            android:id="@+id/tvNombreMedicina"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1E293B"
                            tools:text="Amlodipino"/>

                        <TextView
                            android:id="@+id/tvDosisDetalle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textColor="#64748B"
                            android:fontFamily="sans-serif-medium"
                            tools:text="5 mg"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Consejo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/consejoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/cardNextDose">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="#466B95">

                    <TextView
                        android:id="@+id/tvConsejoTitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Consejo de Salud"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tvConsejoDia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="#E2E8F0"
                        android:textSize="15sp"
                        android:lineHeight="22sp"
                        android:alpha="0.9"
                        tools:text="Mantén una dieta baja en sodio, ya que el exceso de sal aumenta la retención de líquidos."/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BottomNavigationView fijo abajo -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="24dp"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:itemRippleColor="#F1F5F9"
        app:itemActiveIndicatorStyle="@style/App.Custom.Indicator"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
