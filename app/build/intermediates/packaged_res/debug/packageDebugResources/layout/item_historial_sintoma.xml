<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_access_time"
                app:tint="#466B95" />

            <TextView
                android:id="@+id/tvHistorialDateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:letterSpacing="0.05"
                android:textAllCaps="true"
                android:textColor="#466B95"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="25/08/2024 | 02:30 PM" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvHistorialSintomas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="2dp"
            android:textColor="#1E293B"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Dolor de cabeza, Visión borrosa, Fuerte dolor" />

        <TextView
            android:id="@+id/tvHistorialNota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#F8FAFC"
            android:padding="12dp"
            android:textColor="#64748B"
            android:textSize="13sp"
            android:fontStyle="italic"
            android:visibility="gone"
            tools:text="Nota: Hoy fue un día muy estresante..."
            tools:visibility="visible" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#F1F5F9" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditarSintoma"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Editar"
                android:textAllCaps="false"
                android:textColor="#466B95"
                android:textStyle="bold"
                app:icon="@drawable/ic_calendar"
                app:iconSize="18dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminarSintoma"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Quitar"
                android:textAllCaps="false"
                android:textColor="#EF4444"
                android:textStyle="bold"
                app:icon="@drawable/ic_delete"
                app:iconSize="18dp"
                app:iconTint="#EF4444" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>